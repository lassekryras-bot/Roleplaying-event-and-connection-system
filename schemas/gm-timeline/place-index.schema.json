{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/place-index.schema.json",
  "title": "Place Index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "items"
  ],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/indexItem"
      }
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "indexItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "headline",
        "file"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^place-[a-z0-9-]+$"
        },
        "headline": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "file": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/session-index.schema.json",
  "title": "Session Index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "items"
  ],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/indexItem"
      }
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "indexItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "headline",
        "file"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^session-[a-z0-9-]+$"
        },
        "headline": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "file": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
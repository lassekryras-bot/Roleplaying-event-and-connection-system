{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/shared-defs.schema.json",
  "title": "Shared Definitions",
  "$defs": {
    "idString": {
      "type": "string",
      "minLength": 1
    },
    "campaignId": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "readAloudSection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "header",
        "trigger",
        "text",
        "completed"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "header": {
          "type": "string",
          "minLength": 1
        },
        "trigger": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "completed": {
          "type": "boolean"
        }
      }
    },
    "checkResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rolledValue",
        "total",
        "outcome"
      ],
      "properties": {
        "rolledValue": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "modifier": {
          "type": "integer"
        },
        "total": {
          "type": "integer"
        },
        "outcome": {
          "type": "string",
          "enum": [
            "success",
            "failure",
            "partial",
            "critical_success",
            "critical_failure"
          ]
        },
        "recordedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "attribute",
        "dc",
        "rollMode"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "attribute": {
          "type": "string",
          "minLength": 1
        },
        "dc": {
          "type": "integer",
          "minimum": 1,
          "maximum": 40
        },
        "rollMode": {
          "type": "string",
          "enum": [
            "manual",
            "d20_button"
          ]
        },
        "result": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/checkResult"
            }
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
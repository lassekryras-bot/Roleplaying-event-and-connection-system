{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/playerCharacter.schema.json",
  "title": "Player Character",
  "description": "Schema for player characters in the campaign tool. Designed to hold stable character truth plus campaign-fit information and starting threads.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "title",
    "summary",
    "status",
    "campaignId",
    "concept",
    "campaignFitSummary",
    "startingThreadIds",
    "coreThreadIds",
    "relations"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^pc-[a-z0-9-]+$"
    },
    "type": {
      "type": "string",
      "const": "playerCharacter"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "retired",
        "dead",
        "missing",
        "archived"
      ]
    },
    "campaignId": {
      "type": "string",
      "minLength": 1
    },
    "ancestry": {
      "type": [
        "string",
        "null"
      ]
    },
    "class": {
      "type": [
        "string",
        "null"
      ]
    },
    "age": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "concept": {
      "type": "string",
      "minLength": 1
    },
    "partyRole": {
      "type": [
        "string",
        "null"
      ]
    },
    "background": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "origin": {
          "type": [
            "string",
            "null"
          ]
        },
        "history": {
          "type": [
            "string",
            "null"
          ]
        },
        "incitingIncident": {
          "type": [
            "string",
            "null"
          ]
        },
        "reasonInCity": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "currentSituation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "overview": {
          "type": [
            "string",
            "null"
          ]
        },
        "legalStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "socialStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "currentProblem": {
          "type": [
            "string",
            "null"
          ]
        },
        "currentLocationId": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "goals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "shortTerm": {
          "type": [
            "string",
            "null"
          ]
        },
        "midTerm": {
          "type": [
            "string",
            "null"
          ]
        },
        "longTerm": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "traits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strengths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "flaws": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "personality": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "spotlight": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "themes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "gmNotes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "connections": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "importantNpcIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "importantLocationIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "importantThreadIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "importantHookIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "relationshipNotes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "label",
          "role"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "note": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "default": []
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "signatureItems": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "specialCapabilities": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "campaignFitSummary": {
      "type": "string",
      "minLength": 1
    },
    "startingThreadIds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "default": []
    },
    "coreThreadIds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "default": []
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "relations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relation"
      },
      "default": []
    }
  },
  "$defs": {
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "targetId"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "dependsOn",
            "unlocks",
            "follows",
            "modifies",
            "occursAt",
            "belongsTo",
            "relatedTo",
            "appliesTo",
            "contains",
            "partOf",
            "involves",
            "blocks"
          ]
        },
        "targetId": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": "string"
        },
        "strength": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "central"
          ]
        },
        "origin": {
          "type": "string"
        },
        "active": {
          "type": "boolean"
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "event.schema.json",
  "title": "Event",
  "description": "Discrete thing that can happen or has happened.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "title",
    "summary",
    "status"
  ],
  "$defs": {
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "targetId"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "dependsOn",
            "unlocks",
            "follows",
            "modifies",
            "occursAt",
            "belongsTo",
            "relatedTo",
            "appliesTo",
            "contains",
            "partOf",
            "involves",
            "blocks"
          ]
        },
        "targetId": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "inactive",
            "draft"
          ]
        }
      }
    }
  },
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^event-[a-z0-9-]+$"
    },
    "type": {
      "const": "event"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "locked",
        "available",
        "active",
        "resolved",
        "missed",
        "archived"
      ]
    },
    "eventType": {
      "type": [
        "string",
        "null"
      ]
    },
    "createdEffectIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^effect-[a-z0-9-]+$"
      },
      "uniqueItems": true,
      "default": []
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "relations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relation"
      },
      "default": []
    }
  }
}

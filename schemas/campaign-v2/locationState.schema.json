{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "locationState.schema.json",
  "title": "LocationState",
  "description": "Playable state of a location at a point in progression.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "locationId",
    "title",
    "summary",
    "status"
  ],
  "$defs": {
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "targetId"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "dependsOn",
            "unlocks",
            "follows",
            "modifies",
            "occursAt",
            "belongsTo",
            "relatedTo",
            "appliesTo",
            "contains",
            "partOf",
            "involves",
            "blocks"
          ]
        },
        "targetId": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "inactive",
            "draft"
          ]
        }
      }
    }
  },
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^location-state-[a-z0-9-]+$"
    },
    "type": {
      "const": "locationState"
    },
    "locationId": {
      "type": "string",
      "pattern": "^location-[a-z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "available",
        "active",
        "resolved",
        "archived"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "relations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relation"
      },
      "default": []
    }
  }
}

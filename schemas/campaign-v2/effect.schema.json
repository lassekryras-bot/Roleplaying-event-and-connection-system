{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "effect.schema.json",
  "title": "Effect",
  "description": "Ongoing condition, consequence, pressure, or contextual modifier.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "title",
    "summary",
    "status"
  ],
  "$defs": {
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "targetId"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "dependsOn",
            "unlocks",
            "follows",
            "modifies",
            "occursAt",
            "belongsTo",
            "relatedTo",
            "appliesTo",
            "contains",
            "partOf",
            "involves",
            "blocks"
          ]
        },
        "targetId": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "inactive",
            "draft"
          ]
        }
      }
    }
  },
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^effect-[a-z0-9-]+$"
    },
    "type": {
      "const": "effect"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "resolved",
        "archived"
      ]
    },
    "effectType": {
      "type": [
        "string",
        "null"
      ]
    },
    "scope": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "local",
        "subtree",
        "city",
        null
      ]
    },
    "severity": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "low",
        "medium",
        "high",
        "critical",
        null
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "relations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relation"
      },
      "default": []
    }
  }
}

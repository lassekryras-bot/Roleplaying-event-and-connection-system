{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "location.schema.json",
  "title": "Location",
  "description": "Stable identity of a place. Keep this object clean and lightweight.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "title",
    "campaignId",
    "summary",
    "tags"
  ],
  "$defs": {
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "targetId"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "dependsOn",
            "unlocks",
            "follows",
            "modifies",
            "occursAt",
            "belongsTo",
            "relatedTo",
            "appliesTo",
            "contains",
            "partOf",
            "involves",
            "blocks"
          ]
        },
        "targetId": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "inactive",
            "draft"
          ]
        }
      }
    }
  },
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^location-[a-z0-9-]+$"
    },
    "type": {
      "const": "location"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "campaignId": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "parentLocationId": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^location-[a-z0-9-]+$"
    },
    "relations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relation"
      },
      "default": []
    }
  }
}

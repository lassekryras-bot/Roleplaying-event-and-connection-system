{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://living-campaign.dev/schemas/campaign/entity.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "$ref": "./common.schema.json#/$defs/id"
    },
    "type": {
      "$ref": "./common.schema.json#/$defs/linkedEntityType"
    },
    "name": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    },
    "playerVisible": {
      "type": "boolean"
    }
  },
  "required": ["id", "type", "name", "playerVisible"]
}

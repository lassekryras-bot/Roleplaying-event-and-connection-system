{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://living-campaign.dev/schemas/campaign/player-profiles.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "userId": {
        "$ref": "./common.schema.json#/$defs/id"
      },
      "username": {
        "$ref": "./common.schema.json#/$defs/nonEmptyString"
      },
      "displayName": {
        "$ref": "./common.schema.json#/$defs/nonEmptyString"
      },
      "patternId": {
        "$ref": "./common.schema.json#/$defs/id"
      },
      "perspectivePatternIds": {
        "$ref": "./common.schema.json#/$defs/idArray"
      },
      "perspectiveThreadIds": {
        "$ref": "./common.schema.json#/$defs/idArray"
      }
    },
    "required": ["userId", "username", "displayName", "patternId"]
  }
}

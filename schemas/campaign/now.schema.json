{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://living-campaign.dev/schemas/campaign/now.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "const": "now"
    },
    "title": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    },
    "playerSummary": {
      "$ref": "./common.schema.json#/$defs/text"
    },
    "gmTruth": {
      "$ref": "./common.schema.json#/$defs/text"
    }
  },
  "required": ["id", "title", "playerSummary"]
}

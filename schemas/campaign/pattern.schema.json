{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://living-campaign.dev/schemas/campaign/pattern.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "$ref": "./common.schema.json#/$defs/id"
    },
    "title": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    },
    "summary": {
      "$ref": "./common.schema.json#/$defs/text"
    },
    "escalationLevel": {
      "type": "integer",
      "minimum": 1
    },
    "threadIds": {
      "$ref": "./common.schema.json#/$defs/idArray"
    },
    "playerVisible": {
      "type": "boolean"
    },
    "staging": {
      "$ref": "./common.schema.json#/$defs/staging"
    }
  },
  "required": ["id", "title", "summary", "escalationLevel", "threadIds", "playerVisible"]
}

{
  "name": "roleplaying-event-and-connection-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "test": "npm run test:unit && npm run test:integration && npm run test:contract && npm run test:behavior",
    "test:unit": "node --test \"tests/unit/**/*.test.js\"",
    "test:integration": "node --test \"tests/integration/**/*.test.js\"",
    "test:behavior": "node tests/behavior/run-behavior-tests.js",
    "test:behavior:smoke": "BEHAVIOR_TAGS=\"@smoke\" node tests/behavior/run-behavior-tests.js",
    "test:behavior:full": "BEHAVIOR_TAGS=\"@full\" node tests/behavior/run-behavior-tests.js",
    "test:coverage": "node scripts/run-backend-coverage.mjs",
    "coverage:ratchet": "node scripts/check-coverage-ratchet.mjs",
    "test:contract": "node --test \"tests/contract/**/*.test.js\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "typescript": "5.5.4",
    "@types/node": "20.14.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0"
  }
}
